# 复制本文件为 .env 并填入真实值；.env 不会被提交（已在 .gitignore）
# ============================================================

# ===== Binance API（仅开启「读取 + 合约交易」，关闭提现权限）=====
# Testnet 与 Mainnet 的 key 不同；切换 mode 时记得同步更换这里的 key
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ===== LLM 决策 =====
# API Key 通过 Web 看板的 LLM Profile 页面按环境添加、测试和动态切换。

# ===== Telegram 告警（可选，notify.telegram_enabled=true 时才需要）=====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
